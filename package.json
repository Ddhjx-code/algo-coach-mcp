{
  "name": "algo-coach-mcp",
  "version": "0.2.2",
  "description": "Interactive algorithm coach MCP server powered by 代码随想录",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "algo-coach-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "skill",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "sync": "tsx scripts/sync-leetcode.ts",
    "sync:resume": "tsx scripts/sync-leetcode.ts --resume",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
